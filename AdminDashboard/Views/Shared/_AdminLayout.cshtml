@*
    ============================================================
    Views/Shared/_AdminLayout.cshtml
    ------------------------------------------------------------
    The LAYOUT. Everything shared by every admin page lives here:
    the <head>, the sidebar, the top bar, the footer, the scripts.

    Two mechanisms let a child View inject its own content:

      @RenderBody()          -> the child View's main content.
                                Exactly ONE per layout. Required.

      @RenderSection(name)   -> a NAMED hole the child View fills
                                with @section name { ... }.
                                Many allowed. Can be optional
                                (required: false) or mandatory.
    ============================================================
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Campus Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    @* @@ renders as a literal @ — otherwise Razor tries to parse "@400" as code *@
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    @* SECTION 1 — page-specific CSS. Optional: pages that don't need it just skip it. *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="admin-shell">

        @* Shared partial — sidebar markup lives in its own file *@
        <partial name="_Sidebar" />

        <div class="admin-main">

            @* Shared partial — top bar with search and profile *@
            <partial name="_TopBar" />

            <div class="page-header">
                <div>
                    @* SECTION 2 — breadcrumb. required: true means EVERY page
                       MUST define it, or Razor throws an error at runtime. *@
                    @await RenderSectionAsync("Breadcrumb", required: true)

                    <h1 class="page-title">@ViewData["Title"]</h1>
                </div>

                <div class="page-actions">
                    @* SECTION 3 — optional buttons on the right of the header *@
                    @await RenderSectionAsync("PageActions", required: false)
                </div>
            </div>

            <main class="page-body">
                @*
                    ==========================================
                    THE BODY. Whatever is in the child View
                    (outside of any @section block) renders here.
                    ==========================================
                *@
                @RenderBody()
            </main>

            <footer class="admin-footer">
                &copy; @DateTime.Now.Year Campus Admin · ASP.NET Core MVC
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @* SECTION 4 — page-specific JS, loaded last so it can use jQuery/Bootstrap.
       This is the single most common use of @RenderSection. *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
