@model List<AdminPanel.Models.UserAccount>
@{
    ViewData["Title"] = "Users";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Users</li>
        </ol>
    </nav>
}

@section PageActions {
    <button class="btn btn-primary btn-sm" type="button">Add user</button>
}

@* ---------- @RenderBody() content starts here ---------- *@

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>All accounts <span class="badge bg-secondary">@Model.Count</span></span>
        <input id="userFilter" class="form-control form-control-sm w-auto"
               type="search" placeholder="Filter by name or email…" />
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle" id="usersTable">
            <thead>
                <tr>
                    <th style="width:60px;">#</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Joined</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-muted">@user.Id</td>
                        <td>@user.FullName</td>
                        <td class="text-muted">@user.Email</td>
                        <td><span class="badge bg-secondary">@user.Role</span></td>
                        <td>
                            @{
                                var statusClass = user.Status switch
                                {
                                    "Active"    => "bg-success",
                                    "Pending"   => "bg-warning text-dark",
                                    "Suspended" => "bg-danger",
                                    _           => "bg-secondary"
                                };
                            }
                            <span class="badge @statusClass">@user.Status</span>
                        </td>
                        <td class="text-muted">@user.JoinedOn.ToString("MMM d, yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* This page's Scripts section is completely different from the Dashboard's —
   no Chart.js here, just a small jQuery filter. *@
@section Scripts {
    <script>
        $('#userFilter').on('keyup', function () {
            const term = $(this).val().toLowerCase();
            $('#usersTable tbody tr').each(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(term) > -1);
            });
        });
    </script>
}
